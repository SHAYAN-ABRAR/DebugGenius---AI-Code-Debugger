# Copy this file to ".env" and fill in your key.
# Get a key at https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_api_key_here

# Optional: override the vision model (defaults to gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR)
# DEBUGGENIUS_LOG_LEVEL=INFO
