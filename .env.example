# Copy this file to ".env" and adjust as needed.

# ── AI provider ───────────────────────────────────────────────────────────
# Which backend to use: "ollama" (default, no key needed) or "gemini".
AI_PROVIDER=ollama

# ── Ollama (used when AI_PROVIDER=ollama) ─────────────────────────────────
# LOCAL daemon: just run a server. For "-cloud" models, run `ollama signin`
#   once — no key needed here; the daemon proxies your cloud credentials.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
#
# REMOTE (no local daemon, e.g. deployment): point OLLAMA_HOST at the cloud
#   endpoint and supply an API key (sent as "Authorization: Bearer ...").
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=your_ollama_api_key_here

# ── Gemini (used when AI_PROVIDER=gemini) ─────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikeys
# GEMINI_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── Misc ──────────────────────────────────────────────────────────────────
# DEBUGGENIUS_LOG_LEVEL=INFO
